// Countdown progress arc indicator - shows animated arc during timer countdown
$rect <10,0,210,40>
$output false
class ProgressIndicator : Core::Group
{
  $rect <400,40,640,80>
  inherited property Bounds = <0,0,360,320>;

  // Arc path for circular countdown indicator (gap at top where no arc is drawn)
  $rect <400,80,640,120>
  object Graphics::ArcPath TimerArcPath
  {
    preset EndAngle = 410.0;
    preset StartAngle = 130.0;
    preset Radius = 155.0;
    preset Style = Graphics::ArcStyle.Arc;
  }

  // Stroke renderer for the countdown arc
  $rect <20,20,160,60>
  object Views::StrokePath TimerArcStroke
  {
    preset Bounds = <0,0,360,320>;
    preset Color = #FFFFFFFF;
    preset Offset = <180,180>;
    preset EndCap = Graphics::PathCap.Round;
    preset StartCap = Graphics::PathCap.Round;
    preset Width = 8.0;
    preset Path = TimerArcPath;
    preset Visible = true;
  }

  // Total countdown duration in seconds - setting this property starts the countdown \
  // automatically
  $rect <400,160,640,200>
  property int32 TotalSeconds = 0;

  // Remaining seconds in countdown (parent reads via OnTick)
  $rect <400,200,640,240>
  property int32 RemainingSeconds = 0;

  // Callback fired when countdown reaches zero
  $rect <640,120,880,160>
  property slot OnCountdownDone = null;

  // Callback fired every second during countdown
  $rect <400,120,640,160>
  property slot OnTick = null;

  // 1-second periodic timer for countdown
  $rect <929,81,1169,121>
  object Core::Timer CountdownTimer
  {
    preset OnTrigger = OnCountdownTick;
    preset Period = 1000;
    preset Enabled = false;
  }

  // Continuous arc animation effect - animates from TotalSeconds*1000 down to 0
  $rect <929,41,1169,81>
  object Effects::Int32Effect ArcEffect
  {
    preset OnAnimate = OnArcAnimate;
    preset Timing = Effects::Timing.Linear;
    preset NoOfCycles = 1;
    preset Enabled = false;
  }

  // Called every animation frame to smoothly shrink the arc. The arc spans 280 degrees \
  // Maps the remaining milliseconds to an arc EndAngle using current ArcStart/ArcSpan.
  $rect <1169,41,1409,81>
  slot OnArcAnimate
  {
    if ( pure MaxSeconds > 0 )
      TimerArcPath.EndAngle = ArcStart + ArcSpan * (float)ArcEffect.Value / (float)( pure MaxSeconds * 1000 );
  }

  // Fires once per second. Decrements the remaining time, notifies the parent (to \
  // update the MM:SS display), and when zero is reached stops everything and fires \
  // OnCountdownDone.
  $rect <1169,81,1409,121>
  slot OnCountdownTick
  {
    // Decrement remaining time by one second
    pure RemainingSeconds = pure RemainingSeconds - 1;

    // Notify the parent so it can update the MM:SS display
    signal OnTick;

    if ( pure RemainingSeconds <= 0 )
    {
      // Clamp to zero
      pure RemainingSeconds = 0;

      // Stop timers
      CountdownTimer.Enabled = false;
      ArcEffect.Enabled = false;

      // Notify the parent that countdown is done
      signal OnCountdownDone;
    }
  }

  // Maximum selectable time in seconds (used for arc proportion)
  $rect <400,240,640,280>
  property int32 MaxSeconds = 60;

  // Arc geometry: start angle and total span
  $rect <400,280,640,320>
  var float ArcStart = 130.0;

  $rect <640,280,880,320>
  var float ArcSpan = 280.0;

  // Set static arc fill proportional to aSeconds / MaxSeconds (no countdown)
  // Uses preview angles that avoid the visible button bar.
  $rect <640,240,880,280>
  method void SetPreview( arg int32 aSeconds )
  {
    // Stop any running countdown
    CountdownTimer.Enabled = false;
    ArcEffect.Enabled = false;

    if ( pure MaxSeconds > 0 )
      TimerArcPath.EndAngle = ArcStart + ArcSpan * (float)aSeconds / (float)pure MaxSeconds;
    else
      TimerArcPath.EndAngle = ArcStart;
  }

  // Start the countdown.
  $rect <640,160,880,200>
  method void StartCountdown( arg int32 aSeconds )
  {
    pure TotalSeconds = aSeconds;

    if ( aSeconds <= 0 )
      return;

    // Initialize remaining seconds to the full duration
    pure RemainingSeconds = aSeconds;

    // Start with arc fill proportional to aSeconds / MaxSeconds
    if ( pure MaxSeconds > 0 )
      TimerArcPath.EndAngle = ArcStart + ArcSpan * (float)aSeconds / (float)pure MaxSeconds;
    else
      TimerArcPath.EndAngle = ArcStart + ArcSpan;

    // Configure the arc effect to sweep down to empty
    ArcEffect.Enabled = false;
    ArcEffect.Value1 = aSeconds * 1000;
    ArcEffect.Value2 = 0;
    ArcEffect.CycleDuration = (int32)( aSeconds * 1000 );
    ArcEffect.Enabled = true;

    // Start 1-second tick timer for digit display
    CountdownTimer.Enabled = false;
    CountdownTimer.Enabled = true;
  }

  // Add or remove seconds during a running countdown. Restarts the arc effect
  // from the current visual position so the sweep continues smoothly.
  $rect <640,280,880,320>
  method void AdjustTime( arg int32 aDelta )
  {
    var int32 newRemaining = pure RemainingSeconds + aDelta;

    // Clamp to valid range
    if ( newRemaining < 1 )
      newRemaining = 1;
    if ( newRemaining > pure MaxSeconds )
      newRemaining = pure MaxSeconds;

    pure RemainingSeconds = newRemaining;

    // Notify parent to update MM:SS display
    signal OnTick;

    // Restart arc effect from current visual position to 0
    var int32 currentMs = newRemaining * 1000;
    ArcEffect.Enabled = false;
    ArcEffect.Value1 = currentMs;
    ArcEffect.Value2 = 0;
    ArcEffect.CycleDuration = currentMs;
    ArcEffect.Enabled = true;
  }

  // Circular touch handler for adjusting time by rotating on the arc
  $rect <20,60,160,100>
  object Core::RotateTouchHandler ArcTouchHandler
  {
    preset Bounds = <0,0,360,320>;
    preset OnRotate = OnArcRotate;
    preset OnStart = OnArcTouchStart;
    preset CenterOffset = <0,0>;
  }

  // Seconds value when touch started (baseline for drag delta)
  $rect <929,240,1169,280>
  var int32 TouchStartSeconds;

  // Touch started - save current seconds as baseline
  $rect <929,200,1169,240>
  slot OnArcTouchStart
  {
    // Derive current seconds from the arc position
    if ( ArcSpan > 0.0 )
      TouchStartSeconds = (int32)((TimerArcPath.EndAngle - ArcStart) / ArcSpan * (float)pure MaxSeconds);
    else
      TouchStartSeconds = 0;
  }

  // Dragging on the arc - map rotation to seconds
  $rect <1167,200,1407,240>
  slot OnArcRotate
  {
    // Map rotation degrees to seconds: full ArcSpan = MaxSeconds
    var float degreesPerSecond = ArcSpan / (float)pure MaxSeconds;
    var int32 deltaSec = -(int32)((float)ArcTouchHandler.Relative / degreesPerSecond);
    var int32 newSec = TouchStartSeconds + deltaSec;

    // Clamp
    if ( newSec < 0 )
      newSec = 0;
    if ( newSec > pure MaxSeconds )
      newSec = pure MaxSeconds;

    // Update preview or running countdown
    if ( CountdownTimer.Enabled )
    {
      // Running mode - use AdjustTime relative to current
      var int32 diff = newSec - pure RemainingSeconds;
      if ( diff != 0 )
        AdjustTime( diff );
    }
    else
    {
      // Preview mode - update arc directly and notify parent
      pure RemainingSeconds = newSec;
      SetPreview( newSec );
      signal OnTick;
    }
  }

  // State Handling and Initialization
  note group Note1
  {
    attr Bounds = <380,-9,900,340>;
  }

  // Arc Animation
  note group Note2
  {
    attr Bounds = <909,-9,1429,141>;
  }

  // Arc Touch Handling
  note group Note3
  {
    attr Bounds = <909,149,1429,299>;
  }

  // Directives to adapt the order of the above members according to how these members 
  // where arranged when the project content was stored. In this manner the storage 
  // and the expected order of the members don't depend. Merging of changes in the 
  // project files is simplified.
  $member Bounds
  $member TimerArcPath
  $member TimerArcStroke
  $member TotalSeconds
  $member RemainingSeconds
  $member MaxSeconds
  $member ArcStart
  $member ArcSpan
  $member SetPreview
  $member StartCountdown
  $member AdjustTime
  $member OnCountdownDone
  $member OnTick
  $member CountdownTimer
  $member ArcEffect
  $member OnArcAnimate
  $member OnCountdownTick
  $member ArcTouchHandler
  $member TouchStartSeconds
  $member OnArcTouchStart
  $member OnArcRotate
  $member Note1
  $member Note2
  $member Note3
}

// Control bar component - circles, arrow button, press animations
$rect <10,-40,210,0>
