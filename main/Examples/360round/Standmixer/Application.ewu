  array Resources::Bitmap IconBitmaps[ 6 ] =
  (
    Default[0] = Application::IconChop;
    Default[1] = Application::IconCrush;
    Default[2] = Application::IconFroth;
    Default[3] = Application::IconShake;
    Default[4] = Application::IconStir;
    Default[5] = Application::IconStrain;
  );

  // Slot view references for the 5 display positions
  $rect <641,81,881,121>
  array Views::Image IconSlots[ 5 ] =
  (
    Default[0] = IconSlot0;
    Default[1] = IconSlot1;
    Default[2] = IconSlot2;
    Default[3] = IconSlot3;
    Default[4] = IconSlot4;
  );

  $rect <20,20,160,60>
  object Views::Image CircleInner
  {
    preset Bounds = <95,102,266,188>;
    preset AutoSize = true;
    preset Color = #FFFFFFBB;
    preset Bitmap = Application::CircleInnerFill;
    preset Visible = true;
  }

  // Arrow button icon in the inner circle
  $rect <20,20,160,60>
  object Views::Image ArrowButton
  {
    preset Bounds = <155,121,205,166>;
    preset AutoSize = true;
    preset Color = #FFFFF3FF;
    preset Bitmap = Application::IconArrow;
  }

  // Touch handler for the arrow button
  $rect <20,20,160,60>
  object Core::SimpleTouchHandler ArrowTouchHandler
  {
    preset Point4 = <85,182>;
    preset Point3 = <281,182>;
    preset Point2 = <223,103>;
    preset Point1 = <132,103>;
    preset OnRelease = OnArrowRelease;
    preset OnPress = OnArrowPress;
  }

  // Callback fired when arrow button is released
  $rect <401,221,641,261>
  property slot OnAction = null;

  // Arrow button bitmap - parent sets arrow or play-pause icon
  $rect <930,30,1170,70>
  property Resources::Bitmap ArrowBitmap = null;

  $rect <1170,30,1410,70>
  onset ArrowBitmap
  {
    // Store the new bitmap and push it to the visible image view
    pure ArrowBitmap = value;
    ArrowButton.Bitmap = value;
  }

  // Touch press on the arrow area - dim to pressed gray
  $rect <930,110,1170,150>
  slot OnArrowPress
  {
    AnimateButton( #C0C0C0FF );
  }

  // Touch released on the arrow area - restore to white and notify parent
  $rect <1170,110,1410,150>
  slot OnArrowRelease
  {
    AnimateButton( #FFFFFFFF );
    signal OnAction;
  }

  // Set button color on arrow, inner circle and selection highlight
  $rect <930,70,1170,110>
  method void AnimateButton( arg color aTarget )
  {
    ArrowButton.Color = aTarget;
    CircleInner.Color = aTarget;
    Selected.Color = aTarget;
  }

  // Container for outer ring, selection highlight and carousel icons
  $rect <930,32,1170,72>
  object Core::Group OuterGroup
  {
    preset Bounds = <0,0,360,220>;
  }

  // Container for inner circle, blur mask and arrow button
  $rect <1170,32,1410,72>
  object Core::Group InnerGroup
  {
    preset Bounds = <0,0,360,220>;
  }

  $rect <401,31,641,71>
  inherited method Init()
  {
    // Reparent outer views into OuterGroup for batch visibility control
    Remove( CircleOuter );
    Remove( Selected );
    Remove( IconSlot0 );
    Remove( IconSlot1 );
    Remove( IconSlot2 );
    Remove( IconSlot3 );
    Remove( IconSlot4 );

    OuterGroup.Add( CircleOuter, 0 );
    OuterGroup.Add( IconSlot0, 0 );
    OuterGroup.Add( IconSlot1, 0 );
    OuterGroup.Add( IconSlot3, 0 );
    OuterGroup.Add( IconSlot4, 0 );

    // Selected fill and center icon stay outside OuterGroup so they remain
    // visible when the outer ring and non-selected icons are hidden
    Add( Selected, 0 );
    Add( IconSlot2, 0 );

    // Reparent inner views into InnerGroup for batch visibility control
    Remove( CircleInner );
    Remove( ArrowButton );

    InnerGroup.Add( CircleInner, 0 );
    InnerGroup.Add( ArrowButton, 0 );

    // Ensure ArrowTouchHandler is always at the top of z-order so it gets
    // touch events before RotateHandler or any other view
    Remove( ArrowTouchHandler );
    Add( ArrowTouchHandler, 0 );

    // Position icons at initial angle
    UpdateIconPositions( 0.0 );
  }

  // Recalculate icon positions and opacity for the circular carousel. Uses 5 virtualized \
  // image slots to display the 6 mode icons on a semicircular arc. Icons near the \
  // top (90 degrees) are fully opaque; icons toward the edges fade out proportionally.
  $rect <930,400,1170,440>
  method void UpdateIconPositions( arg float aAngle )
  {
    var int32 centerX = 180;
    var int32 centerY = 186;
    var int32 radius = 118;
    var int32 halfSize = 34;

    // Phase: how far we've scrolled in mode-steps (1 step = 60 degrees of rotation)
    var float phase = aAngle / 60.0;

    // Nearest integer phase = the mode closest to the top position
    var int32 centerPhase = (int32)math_round( phase );

    var int32 s;

    for ( s = 0; s < 5; s = s + 1 )
    {
      var int32 modePhase = centerPhase + s - 2;
      var int32 modeIndex = modePhase % 6;

      if ( modeIndex < 0 )
        modeIndex = modeIndex + 6;

      var float visualAngle = 90.0 - ((float)modePhase - phase) * 45.0;
      var int32 x = centerX + (int32)((float)radius * math_cos( visualAngle ));
      var int32 y = centerY - (int32)((float)radius * math_sin( visualAngle ));

      var float angleDiff = visualAngle - 90.0;
      if ( angleDiff < 0.0 )
        angleDiff = -angleDiff;
      var int32 opacity = 255 - (int32)(angleDiff / 90.0 * 200.0);
      if ( opacity < 55 )
        opacity = 55;

      // Only assign properties that actually changed to minimize invalidations
      var Resources::Bitmap newBmp = IconBitmaps[modeIndex];
      if ( IconSlots[s].Bitmap != newBmp )
        IconSlots[s].Bitmap = newBmp;

      var rect newRect = rect( x - halfSize, y - halfSize, x + halfSize, y + halfSize );
      if ( IconSlots[s].Bounds != newRect )
        IconSlots[s].Bounds = newRect;

      var color oldClr = IconSlots[s].Color;
      var color newClr = color( oldClr.red, oldClr.green, oldClr.blue, (uint8)opacity );
      if ( oldClr != newClr )
        IconSlots[s].Color = newClr;
    }
  }

  // Wrap an arbitrary angle into the 0..360 range using modular arithmetic
  $rect <1170,400,1410,440>
  method float NormalizeAngle( arg float aAngle )
  {
    // Shift into positive range, then wrap with modulo
    var float result = aAngle;

    while ( result < 0.0 )
      result = result + 360.0;

    while ( result >= 360.0 )
      result = result - 360.0;

    return result;
  }

  // Circular touch handler for rotation gestures
  $rect <20,20,160,60>
  object Core::RotateTouchHandler RotateHandler
  {
    preset Bounds = <0,6,360,186>;
    preset OnRotate = HandleRotation;
    preset OnEnd = OnRelease;
    preset OnStart = OnTouchStart;
    preset CenterOffset = <0,180>;
  }

  // FloatEffect interpolating the carousel angle (time-based, skips frames on slow \
  // HW)
  $rect <930,240,1170,280>
  object Effects::FloatEffect IconMoveEffect
  {
    preset OnFinished = OnIconMoveDone;
    preset OnAnimate = OnIconAnimate;
    preset Timing = Effects::Timing.FastIn_EaseOut;
    preset NoOfCycles = 1;
    preset CycleDuration = 200;
    preset Enabled = false;
  }

  // Called each rendered frame - interpolates the angle and repositions icons
  $rect <1170,280,1410,320>
  slot OnIconAnimate
  {
    UpdateIconPositions( IconMoveEffect.Value );
  }

  // Animation finished - store final angle and notify parent of new selection
  $rect <1170,240,1410,280>
  slot OnIconMoveDone
  {
    pure CurrentAngle = IconMoveTargetAngle;

    // Update selected index now that icons are at rest
    var float norm = NormalizeAngle( IconMoveTargetAngle );
    var int32 newIndex = ((int32)((norm + 30.0) / 60.0)) % 6;
    if ( newIndex != SelectedIndex )
    {
      SelectedIndex = newIndex;
      signal OnSelectionChanged;
    }
  }

  // Target angle for the running animation
  $rect <641,261,881,301>
  var float IconMoveTargetAngle;

  // Animate icons from the current angle to the target angle
  $rect <930,280,1170,320>
  method void StartIconEffects( arg float aTargetAngle )
  {
    // Continue from the current animated position (no snap, no stop)
    var float startAngle;
    if ( IconMoveEffect.Enabled )
    {
      startAngle = IconMoveEffect.Value;
      IconMoveEffect.Enabled = false;
    }
    else
      startAngle = pure CurrentAngle;

    pure CurrentAngle = startAngle;
    IconMoveTargetAngle = aTargetAngle;

    // Start effect: interpolate from current position to target
    IconMoveEffect.Value1 = startAngle;
    IconMoveEffect.Value2 = aTargetAngle;
    IconMoveEffect.Enabled = true;
  }

  // Current rotation angle of the icon carousel
  $rect <401,311,641,351>
  property float CurrentAngle = 0.0;

  // Update visuals whenever the carousel angle changes. Repositions all icons on \
  // the arc and computes which mode is nearest to the top center. If the nearest \
  // mode changed, fires OnSelectionChanged to the parent.
  $rect <641,311,881,351>
  onset CurrentAngle
  {
    // Skip redundant updates when the angle hasn't actually changed
    if ( value == pure CurrentAngle )
      return;

    // Store new angle and reposition all icon slots on the arc
    pure CurrentAngle = value;
    UpdateIconPositions( pure CurrentAngle );

    // Track which mode is nearest (background change deferred to OnIconMoveDone)
    var float normalized = NormalizeAngle( value );
    var int32 nearestIndex = ((int32)((normalized + 30.0) / 60.0)) % 6;
    SelectedIndex = nearestIndex;
  }

  // Angle at the moment touch started
  $rect <401,131,641,171>
  var float StartAngle;

  // Currently selected mode index (0-5)
  $rect <641,131,881,171>
  var int32 SelectedIndex = 0;

  // Blocks rotation when true (set by parent during non-IDLE states)
  $rect <401,181,641,221>
  property bool Locked = false;

  // Callback fired on any touch start (for done-screen dismiss)
  $rect <641,181,881,221>
  property slot OnTouch = null;

  // Callback fired when SelectedIndex changes (for background updates)
  $rect <641,221,881,261>
  property slot OnSelectionChanged = null;

  // Touch started - notifies parent, then snaps any running animation to its target \
  // and saves the current angle as baseline for threshold detection
  $rect <930,320,1170,360>
  slot OnTouchStart
  {
    // Notify parent regardless of Locked state
    signal OnTouch;

    if ( pure Locked )
      return;

    // If an animation is running, complete it instantly and sync selection
    if ( IconMoveEffect.Enabled )
    {
      IconMoveEffect.Enabled = false;
      CurrentAngle = IconMoveTargetAngle;

      var float norm = NormalizeAngle( IconMoveTargetAngle );
      var int32 newIndex = ((int32)((norm + 30.0) / 60.0)) % 6;
      if ( newIndex != SelectedIndex )
      {
        SelectedIndex = newIndex;
        signal OnSelectionChanged;
      }
    }

    // Save baseline for rotation threshold detection
    StartAngle = pure CurrentAngle;
  }

  // Rotation gesture in progress - icons follow the finger directly
  $rect <930,360,1170,400>
  slot HandleRotation
  {
    if ( pure Locked )
      return;

    // Stop any running animation - finger takes over
    if ( IconMoveEffect.Enabled )
      IconMoveEffect.Enabled = false;

    // Move icons directly with the finger (scaled to match visual arc speed)
    var float totalAngle = StartAngle + (float)RotateHandler.Relative * 2.3;
    CurrentAngle = totalAngle;
  }

  // Touch released - snap to the nearest detent and notify parent of selection
  $rect <1170,320,1410,360>
  slot OnRelease
  {
    if ( pure Locked )
      return;

    // Find nearest detent (multiple of 60 degrees)
    var float angle = pure CurrentAngle;
    var float snapped = math_round( angle / 60.0 ) * 60.0;

    // Animate to the detent
    StartIconEffects( snapped );

    // Notify parent of the final selection (background change)
    var float norm = NormalizeAngle( snapped );
    var int32 newIndex = ((int32)((norm + 30.0) / 60.0)) % 6;
    if ( newIndex != SelectedIndex )
      SelectedIndex = newIndex;
    signal OnSelectionChanged;
  }

  // Rotate the carousel by exactly one mode slot (60 degrees). aDirection: +1 = \
  // clockwise, -1 = counter-clockwise. Called by parent for encoder clicks and keyboard \
  // arrow presses. Ignores the call if the carousel is locked or already animating.
  $rect <1170,360,1410,400>
  method void RotateStep( arg int32 aDirection )
  {
    // Block rotation while carousel is locked
    if ( pure Locked )
      return;

    // Chain from previous target if already animating, else from current angle
    var float baseAngle;
    if ( IconMoveEffect.Enabled )
      baseAngle = IconMoveTargetAngle;
    else
      baseAngle = pure CurrentAngle;

    // Animate icons to the next 60-degree detent
    StartIconEffects( baseAngle + (float)aDirection * 60.0 );
  }

  // Center Button
  note group Note
  {
    attr Bounds = <910,-8,1430,180>;
  }

  // State Handling and Initialization
  note group Note1
  {
    attr Bounds = <380,-9,900,370>;
  }

  // Icon Carousel
  note group Note2
  {
    attr Bounds = <910,190,1430,460>;
  }

