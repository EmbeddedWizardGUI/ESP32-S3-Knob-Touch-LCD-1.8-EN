  $member Bounds
  $member CircleOuter
  $member Selected
  $member IconSlot0
  $member IconSlot1
  $member IconSlot2
  $member IconSlot3
  $member IconSlot4
  $member IconBitmaps
  $member IconSlots
  $member CircleInner
  $member ArrowButton
  $member OnAction
  $member ArrowBitmap
  $member OnSetArrowBitmap
  $member OnArrowPress
  $member OnArrowRelease
  $member AnimateButton
  $member OuterGroup
  $member InnerGroup
  $member UpdateIconPositions
  $member NormalizeAngle
  $member RotateHandler
  $member ArrowTouchHandler
  $member IconMoveEffect
  $member IconMoveTargetAngle
  $member OnIconAnimate
  $member OnIconMoveDone
  $member StartIconEffects
  $member CurrentAngle
  $member OnSetCurrentAngle
  $member StartAngle
  $member SelectedIndex
  $member Locked
  $member OnTouch
  $member OnSelectionChanged
  $member OnTouchStart
  $member HandleRotation
  $member OnRelease
  $member RotateStep
  $member Note
  $member Note1
  $member Note2
}

// Device class implementing the interface between GUI and hardware
$rect <260,329,460,369>
$output false
class DeviceClass
{
  $rect <30,60,230,100>
  inherited method Init()
  {
    aArg;

    $if !$prototyper

      native
      {
        DeviceIntegrationExample_Init();
      }

    $endif
  }

  $rect <230,60,430,100>
  inherited method Done()
  {
    $if !$prototyper

      native
      {
        DeviceIntegrationExample_Done();
      }

    $endif
  }

  // ADC value updated by the encoder via device driver
  $rect <230,420,430,460>
  property int32 AdcValue = 0;

  // Called by device driver to update the ADC value from encoder rotation
  $rect <30,420,230,460>
  $output true
  method void UpdateAdcValue( arg int32 aNewValue )
  {
    if ( aNewValue != pure AdcValue )
    {
      pure AdcValue = aNewValue;
      notifyobservers ^AdcValue;
    }
  }

  // System event triggered when the hardware button is pressed
  $rect <230,540,430,580>
  object Core::SystemEvent HardButtonEvent;

  // Called by device driver when hardware button is pressed
  $rect <30,540,230,580>
  $output true
  method void TriggerHardButtonEvent()
  {
    HardButtonEvent.Trigger( null, false );
  }

  // Directives to adapt the order of the above members according to how these members 
  // where arranged when the project content was stored. In this manner the storage 
  // and the expected order of the members don't depend. Merging of changes in the 
  // project files is simplified.
  $member Done
  $member Init
  $member AdcValue
  $member UpdateAdcValue
  $member HardButtonEvent
  $member TriggerHardButtonEvent
}

