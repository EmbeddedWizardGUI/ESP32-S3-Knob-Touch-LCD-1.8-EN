$version 15.02

// Include the device driver header file to access the device class
$rect <260,289,460,329>
inline Inline
{
  #include "DeviceDriver.h"
}

// State machine phases for the timer workflow
$rect <10,380,210,420>
enum TimerStateEnum
{
  $rect <20,10,220,50>
  item Idle;

  $rect <20,50,220,90>
  item Setting;

  $rect <20,90,220,130>
  item Running;

  $rect <20,130,220,170>
  item Done;
}

// Root component of the Standmixer GUI application. For more information, please \
// visit: https://doc.embedded-wizard.de/
$rect <10,-100,210,-60>
$output false
class Application : Core::Root
{
  $rect <640,40,880,80>
  inherited property Bounds = <0,0,360,360>;

  $rect <400,40,640,80>
  inherited method Init()
  {
    // Initialize video paths per mode
    $if !$prototyper
    VideoSources[0] = "flash://chop.avi";
    VideoSources[1] = "flash://crush.avi";
    VideoSources[2] = "flash://whip.avi";
    VideoSources[3] = "flash://shake.avi";
    VideoSources[4] = "flash://stir.avi";
    VideoSources[5] = "flash://strain.avi";
    $else
    VideoSources[0] = "chop.avi";
    VideoSources[1] = "crush.avi";
    VideoSources[2] = "whip.avi";
    VideoSources[3] = "shake.avi";
    VideoSources[4] = "stir.avi";
    VideoSources[5] = "strain.avi";
    $endif

    // Set initial background
    Background.Bitmap = Backgrounds[0];
    PreviousAdcValue = 0;

    // Create control bar (always present)
    CtrlBar = new Application::ControlBar;
    CtrlBar.OnAction = OnControlBarAction;
    CtrlBar.OnSelectionChanged = OnSelectionChanged;
    CtrlBar.OnTouch = OnCarouselTouch;
    Add( CtrlBar, 0 );

    // Preload video: create decoder early (ESP32 requires first init during boot)
    var string videoPath = VideoSources[0];

    $if $prototyper || $composer
    videoPath = "file://..\\..\\..\\Extensions\\ExternVideo\\Media\\" + videoPath;
    $endif

    VideoSource.Name = videoPath;
    VideoSource.Paused = true;

    /* add a round mask for composer to get an impression of a round display... */
    $if $prototyper

    RoundMaskView = new Views::Image;
    RoundMaskView.Bitmap = Application::RoundMask;
    RoundMaskView.Color = #000000C0;
    RoundMaskView.Bounds = Bounds.orect;
    Add( RoundMaskView, 0 );

    $endif
  }

  // Background image - full display
  $rect <20,20,160,60>
  object Views::Image Background
  {
    preset Bounds = <0,0,360,360>;
    preset Bitmap = Application::BackgroundChop;
  }

  // Overlay for cross-fading to new background (fades in on top, then swapped)
  $rect <160,20,300,60>
  object Views::Image BackgroundNext
  {
    preset Bounds = <0,0,360,360>;
    preset Visible = false;
  }

  // Opacity fade effect for BackgroundNext (0 → 255 cross-fade)
  $rect <400,388,640,428>
  object Effects::Int32Effect BgFadeEffect
  {
    preset OnFinished = OnBgFadeDone;
    preset Timing = Effects::Timing.FastIn_EaseOut;
    preset NoOfCycles = 1;
    preset CycleDuration = 300;
    preset Enabled = false;
    preset Outlet = ^BackgroundNext.Opacity;
  }

  // Fade complete - copy new bitmap to Background and hide the overlay
  $rect <640,388,880,428>
  slot OnBgFadeDone
  {
    Background.Bitmap = BackgroundNext.Bitmap;
    BackgroundNext.Visible = false;
  }

  // Video source for countdown playback (preloaded in Init)
  $rect <929,449,1169,489>
  object Resources::ExternVideo VideoSource
  {
    preset OnChangeState = OnVideoStateChanged;
    preset Speed = 100;
  }

  // Video display view - shown during countdown behind the overlay
  $rect <20,20,160,60>
  object Views::Image VideoView
  {
    preset Bounds = <0,0,360,360>;
    preset Color = #FFFFFFFF;
    preset Alignment = Views::ImageAlignment[AlignHorzCenter, AlignVertCenter, ScaleToFit];
    preset Bitmap = VideoSource;
    preset AlphaBlended = false;
    preset Visible = false;
  }

  // Video file paths per mode (6 entries, configurable per mode)
  $rect <400,128,640,168>
  array string VideoSources[ 6 ];

  // Timer display component (MM:SS text for time selection) - created dynamically
  $rect <640,290,880,330>
  var Application::TimerConfigure TimerCfg = null;

  // Done screen component ("Ready" / "Enjoy your meal!") - created dynamically
  $rect <640,250,880,290>
  var Application::DoneMessage DoneMsg = null;

  // Control bar component (circles, arrow, press animations) - created in Init
  $rect <400,290,640,330>
  var Application::ControlBar CtrlBar = null;

  // Countdown progress arc indicator - created dynamically
  $rect <400,250,640,290>
  var Application::ProgressIndicator ProgressInd = null;

  // Background bitmap references for the 6 modes
  $rect <400,88,640,128>
  array Resources::Bitmap Backgrounds[ 6 ] =
  (
    Default[0] = Application::BackgroundChop;
    Default[1] = Application::BackgroundCrush;
    Default[2] = Application::BackgroundWhip;
    Default[3] = Application::BackgroundShake;
    Default[4] = Application::BackgroundStir;
    Default[5] = Application::BackgroundStrain;
  );

  // Dark background bitmap references for the 6 modes (used during time selection)
  $rect <640,88,880,128>
  array Resources::Bitmap DarkBackgrounds[ 6 ] =
  (
    Default[0] = Application::BackgroundChopDark;
    Default[1] = Application::BackgroundCrushDark;
    Default[2] = Application::BackgroundWhipDark;
    Default[3] = Application::BackgroundShakeDark;
    Default[4] = Application::BackgroundStirDark;
    Default[5] = Application::BackgroundStrainDark;
  );

  // Variable to keep Device alive for the entire lifetime of the application
  $rect <929,42,1169,82>
  var Application::DeviceClass DeviceRef = Application::Device;

  // Previous ADC value for detecting encoder rotation direction
  $rect <929,91,1169,131>
  var int32 PreviousAdcValue;

  // Observer for encoder rotation via ADC value changes
  $rect <929,140,1169,180>
  object Core::PropertyObserver EncoderObserver
  {
    preset OnEvent = onEncoderChange;
    preset Outlet = ^Application::Device.AdcValue;
  }

  // Encoder rotation handler - adjusts timer in SETTING state, rotates carousel \
  // in IDLE
  $rect <929,180,1169,220>
  slot onEncoderChange
  {
    // Compute rotation direction from ADC delta
    var int32 currentAdc = Application::Device.AdcValue;
    var int32 delta = currentAdc - PreviousAdcValue;
    PreviousAdcValue = currentAdc;

    // Timer setting mode - redirect input to timer adjustment
    if ( TimerState == Application::TimerStateEnum.Setting )
    {
      if ( delta > 0 )
        TimerCfg.TimerSeconds = TimerCfg.TimerSeconds + 1;
      else if ( delta < 0 )
        TimerCfg.TimerSeconds = TimerCfg.TimerSeconds - 1;

      if ( TimerCfg.TimerSeconds < 0 )
        TimerCfg.TimerSeconds = 0;

      if ( TimerCfg.TimerSeconds > 60 )
        TimerCfg.TimerSeconds = 60;

      ProgressInd.SetPreview( TimerCfg.TimerSeconds );
      return;
    }

    // Running mode - adjust countdown time with knob
    if ( TimerState == Application::TimerStateEnum.Running )
    {
      if ( delta > 0 )
        ProgressInd.AdjustTime( 1 );
      else if ( delta < 0 )
        ProgressInd.AdjustTime( -1 );
      return;
    }

    // Carousel rotation (RotateStep handles locked/animation checks)
    if ( delta > 0 )
      CtrlBar.RotateStep( -1 );
    else if ( delta < 0 )
      CtrlBar.RotateStep( 1 );
  }

  // System event handler for hardware button press
  $rect <929,220,1169,260>
  object Core::SystemEventHandler HardButtonHandler
  {
    preset OnEvent = onHardButtonEvent;
    preset Event = Application::Device.HardButtonEvent;
  }

  // Timer for auto-releasing button visual after hardware press
  $rect <929,300,1169,340>
  object Core::Timer HardButtonTimer
  {
    preset OnTrigger = OnHardButtonTimerDone;
    preset Period = 0;
    preset Begin = 200;
    preset Enabled = false;
  }

  // Hardware button pressed - show press animation and start 200ms auto-release \
  // timer
  $rect <929,260,1169,300>
  slot onHardButtonEvent
  {
    CtrlBar.AnimateButton( #C0C0C0FF );

    // Restart the auto-release timer (toggle off/on to reset)
    HardButtonTimer.Enabled = false;
    HardButtonTimer.Enabled = true;
  }

  // Auto-release timer fired - play release animation and execute arrow action
  $rect <929,340,1169,380>
  slot OnHardButtonTimerDone
  {
    // Stop the auto-release timer, restore button to white and trigger state machine
    HardButtonTimer.Enabled = false;
    CtrlBar.AnimateButton( #FFFFFFFF );
    HandleArrowAction();
  }

  // Keyboard handlers to simulate encoder rotation in Prototyper mode
  $rect <1220,131,1460,171>
  object Core::KeyPressHandler KeyLeftHandler
  {
    preset OnPress = onKeyLeft;
    preset Filter = Core::KeyCode.Left;
    preset OnHold = onKeyLeftHold;
  }

  $rect <1220,171,1460,211>
  object Core::KeyPressHandler KeyRightHandler
  {
    preset OnPress = onKeyRight;
    preset Filter = Core::KeyCode.Right;
    preset OnHold = onKeyRightHold;
  }

  $rect <1220,91,1460,131>
  object Core::KeyPressHandler KeyEnterHandler
  {
    preset OnPress = onKeyEnter;
    preset Filter = Core::KeyCode.Enter;
  }

  // Keyboard Enter key - simulates hardware button press using same auto-release \
  // timer
  $rect <1220,371,1460,411>
  slot onKeyEnter
  {
    // Show press animation and start auto-release timer (same as hardware button)
    CtrlBar.AnimateButton( #C0C0C0FF );
    HardButtonTimer.Enabled = false;
    HardButtonTimer.Enabled = true;
  }

  // Keyboard Left arrow - decreases timer in SETTING, rotates carousel otherwise
  $rect <1220,211,1460,251>
  slot onKeyLeft
  {
    // Timer setting mode - decrease timer by 1 second
    if ( TimerState == Application::TimerStateEnum.Setting )
    {
      TimerCfg.TimerSeconds = TimerCfg.TimerSeconds - 1;

      if ( TimerCfg.TimerSeconds < 0 )
        TimerCfg.TimerSeconds = 0;

      ProgressInd.SetPreview( TimerCfg.TimerSeconds );
      return;
    }

    // Running mode - decrease countdown time
    if ( TimerState == Application::TimerStateEnum.Running )
    {
      ProgressInd.AdjustTime( -1 );
      return;
    }

    // Carousel rotation (RotateStep handles locked/animation checks)
    CtrlBar.RotateStep( -1 );
  }

  // Keyboard Right arrow - increases timer in SETTING, rotates carousel otherwise
  $rect <1220,251,1460,291>
  slot onKeyRight
  {
    // Timer setting mode - increase timer by 1 second
    if ( TimerState == Application::TimerStateEnum.Setting )
    {
      TimerCfg.TimerSeconds = TimerCfg.TimerSeconds + 1;

      if ( TimerCfg.TimerSeconds > 60 )
        TimerCfg.TimerSeconds = 60;

      ProgressInd.SetPreview( TimerCfg.TimerSeconds );
      return;
    }

    // Running mode - increase countdown time
    if ( TimerState == Application::TimerStateEnum.Running )
    {
      ProgressInd.AdjustTime( 1 );
      return;
    }

    // Carousel rotation (RotateStep handles locked/animation checks)
    CtrlBar.RotateStep( 1 );
  }

  // 200ms gate timer - hold events are ignored while this is running
  $rect <1220,40,1460,80>
  object Core::Timer KeyHoldGateTimer
  {
    preset Period = 0;
    preset Begin = 200;
    preset Enabled = false;
  }

  // Key held down - repeat 1s step with gate timer
  $rect <1220,291,1460,331>
  slot onKeyLeftHold
  {
    if ( TimerState == Application::TimerStateEnum.Running )
    {
      ProgressInd.AdjustTime( -1 );
      return;
    }

    if ( TimerState != Application::TimerStateEnum.Setting )
    {
      // Continuous carousel rotation while key is held
      CtrlBar.RotateStep( -1 );
      return;
    }

    // Skip if last hold step was less than 200ms ago
    if ( KeyHoldGateTimer.Enabled )
      return;

    KeyHoldGateTimer.Enabled = true;
    TimerCfg.TimerSeconds = TimerCfg.TimerSeconds - 1;

    if ( TimerCfg.TimerSeconds < 0 )
      TimerCfg.TimerSeconds = 0;

    ProgressInd.SetPreview( TimerCfg.TimerSeconds );
  }

  // Key held down - repeat 1s step with gate timer
  $rect <1220,331,1460,371>
  slot onKeyRightHold
  {
    if ( TimerState == Application::TimerStateEnum.Running )
    {
      ProgressInd.AdjustTime( 1 );
      return;
    }

    if ( TimerState != Application::TimerStateEnum.Setting )
    {
      // Continuous carousel rotation while key is held
      CtrlBar.RotateStep( 1 );
      return;
    }

    // Skip if last hold step was less than 200ms ago
    if ( KeyHoldGateTimer.Enabled )
      return;

    KeyHoldGateTimer.Enabled = true;
    TimerCfg.TimerSeconds = TimerCfg.TimerSeconds + 1;

    if ( TimerCfg.TimerSeconds > 60 )
      TimerCfg.TimerSeconds = 60;

    ProgressInd.SetPreview( TimerCfg.TimerSeconds );
  }

  // Current phase of the timer workflow
  $rect <400,341,640,381>
  var Application::TimerStateEnum TimerState = Application::TimerStateEnum.Idle;

  // Round display mask (prototyper only, stays on top of z-order)
  $rect <400,381,640,421>
  var Views::Image RoundMaskView = null;

  // Central state machine handler: Idle -> Setting -> Running -> Idle
  $rect <400,640,640,680>
  method void HandleArrowAction()
  {
    if ( TimerState == Application::TimerStateEnum.Idle )
    {
      // IDLE -> SETTING: Switch to dark background and show timer text
      TimerState = Application::TimerStateEnum.Setting;
      CtrlBar.Locked = true;
      CtrlBar.RotateHandler.Enabled = false;
      CtrlBar.ArrowBitmap = Application::IconPlayPause;
      CtrlBar.ArrowButton.FrameNumber = 0;
      CtrlBar.OuterGroup.Visible = false;
      BgFadeEffect.Enabled = false;
      BackgroundNext.Visible = false;
      Background.Bitmap = DarkBackgrounds[CtrlBar.SelectedIndex];

      // Create progress indicator in preview mode
      ProgressInd = new Application::ProgressIndicator;
      ProgressInd.OnCountdownDone = OnCountdownComplete;
      ProgressInd.OnTick = OnProgressTick;
      Add( ProgressInd, 0 );

      // Create timer display with 5s default
      TimerCfg = new Application::TimerConfigure;
      TimerCfg.TimerSeconds = 5;
      Add( TimerCfg, 0 );

      // Show arc preview for default time
      ProgressInd.SetPreview( 5 );

      // Restack CtrlBar on top so its touch handlers always have highest priority
      Remove( CtrlBar );
      Add( CtrlBar, 0 );

      // Restack round mask above everything (prototyper only)
      $if $prototyper
      if ( RoundMaskView != null )
      {
        Remove( RoundMaskView );
        Add( RoundMaskView, 0 );
      }
      $endif
    }
    else if ( TimerState == Application::TimerStateEnum.Setting )
    {
      if ( TimerCfg.TimerSeconds > 0 )
      {
        // SETTING -> RUNNING: Start countdown
        TimerState = Application::TimerStateEnum.Running;
        CtrlBar.ArrowButton.FrameNumber = 1;

        // Hide outer circle, selected fill and selected icon during countdown
        CtrlBar.OuterGroup.Visible = false;
        CtrlBar.Selected.Visible = false;
        CtrlBar.IconSlot2.Visible = false;

        // Start video playback
        StartVideo();

        // Start countdown on existing progress indicator
        ProgressInd.StartCountdown( TimerCfg.TimerSeconds );
      }
      else
      {
        // No time set - return to IDLE
        TimerState = Application::TimerStateEnum.Idle;
        CtrlBar.Locked = false;
        CtrlBar.RotateHandler.Enabled = true;
        CtrlBar.ArrowBitmap = Application::IconArrow;
        CtrlBar.ArrowButton.FrameNumber = 0;
        CtrlBar.OuterGroup.Visible = true;
        BgFadeEffect.Enabled = false;
        BackgroundNext.Visible = false;
        Background.Bitmap = Backgrounds[CtrlBar.SelectedIndex];

        // Destroy progress indicator and timer display
        if ( ProgressInd != null )
        {
          Remove( ProgressInd );
          ProgressInd = null;
        }
        if ( TimerCfg != null )
        {
          Remove( TimerCfg );
          TimerCfg = null;
        }
      }
    }
    else if ( TimerState == Application::TimerStateEnum.Running )
    {
      // RUNNING -> IDLE: Cancel countdown
      StopVideo();
      TimerState = Application::TimerStateEnum.Idle;
      CtrlBar.Locked = false;
      CtrlBar.RotateHandler.Enabled = true;
      CtrlBar.ArrowBitmap = Application::IconArrow;
      CtrlBar.ArrowButton.FrameNumber = 0;
      BgFadeEffect.Enabled = false;
      BackgroundNext.Visible = false;
      Background.Bitmap = Backgrounds[CtrlBar.SelectedIndex];

      // Restore outer circle, selected fill and icons
      CtrlBar.OuterGroup.Visible = true;
      CtrlBar.Selected.Visible = true;
      CtrlBar.IconSlot2.Visible = true;

      // Destroy progress indicator and timer display
      if ( ProgressInd != null )
      {
        Remove( ProgressInd );
        ProgressInd = null;
      }
      if ( TimerCfg != null )
      {
        Remove( TimerCfg );
        TimerCfg = null;
      }
    }
  }

  // Control bar arrow button released - delegate to the state machine
  $rect <640,600,880,640>
  slot OnControlBarAction
  {
    HandleArrowAction();
  }

  // Countdown reached zero - tear down RUNNING state and show done screen
  $rect <640,430,880,470>
  slot OnCountdownComplete
  {
    StopVideo();
    TimerState = Application::TimerStateEnum.Done;

    // Tear down progress arc and timer display
    if ( ProgressInd != null )
    {
      Remove( ProgressInd );
      ProgressInd = null;
    }
    if ( TimerCfg != null )
    {
      Remove( TimerCfg );
      TimerCfg = null;
    }

    // Hide the entire control bar so done message is unobstructed
    CtrlBar.OuterGroup.Visible = false;
    CtrlBar.InnerGroup.Visible = false;

    // Create done message and wire up the auto-dismiss callback
    DoneMsg = new Application::DoneMessage;
    DoneMsg.OnExpired = OnDoneExpired;
    DoneMsg.ModeIndex = CtrlBar.SelectedIndex;
    Add( DoneMsg, 0 );

  }

  // Progress tick - syncs MM:SS display with remaining time once per second
  $rect <400,429,640,469>
  slot OnProgressTick
  {
    // Guard against queued signals arriving after cancellation
    if ( ProgressInd == null )
      return;

    TimerCfg.TimerSeconds = ProgressInd.RemainingSeconds;
  }

  // Done message expired or dismissed - tear down done screen and restore IDLE state
  $rect <400,470,640,510>
  slot OnDoneExpired
  {
    // Remove the done screen from the view hierarchy
    if ( DoneMsg != null )
    {
      Remove( DoneMsg );
      DoneMsg = null;
    }

    // Return to IDLE - unlock carousel, restore arrow icon and background
    TimerState = Application::TimerStateEnum.Idle;
    CtrlBar.Locked = false;
    CtrlBar.RotateHandler.Enabled = true;
    CtrlBar.ArrowBitmap = Application::IconArrow;
    CtrlBar.ArrowButton.FrameNumber = 0;
    BgFadeEffect.Enabled = false;
    BackgroundNext.Visible = false;
    Background.Bitmap = Backgrounds[CtrlBar.SelectedIndex];

    // Make the full control bar visible again
    CtrlBar.OuterGroup.Visible = true;
    CtrlBar.Selected.Visible = true;
    CtrlBar.IconSlot2.Visible = true;
    CtrlBar.InnerGroup.Visible = true;
  }

  // Carousel selection changed - cross-fade background to the newly selected mode
  $rect <400,600,640,640>
  slot OnSelectionChanged
  {
    // Determine the new background bitmap
    var Resources::Bitmap newBmp;
    if ( TimerState == Application::TimerStateEnum.Setting )
      newBmp = DarkBackgrounds[CtrlBar.SelectedIndex];
    else
      newBmp = Backgrounds[CtrlBar.SelectedIndex];

    // Skip fade if already showing the correct background
    if ( newBmp == Background.Bitmap )
      return;

    // Set the new bitmap on the overlay, start the cross-fade
    BackgroundNext.Bitmap = newBmp;
    BackgroundNext.Opacity = 0;
    BackgroundNext.Visible = true;
    BgFadeEffect.Enabled = false;
    BgFadeEffect.Value1 = 0;
    BgFadeEffect.Value2 = 255;
    BgFadeEffect.Enabled = true;
  }

  // Carousel touched - immediately dismiss done screen if showing
  $rect <640,640,880,680>
  slot OnCarouselTouch
  {
    // Touching the carousel during Done state dismisses the done screen
    if ( TimerState == Application::TimerStateEnum.Done )
      postsignal OnDoneExpired;
  }

  // Start video playback for the currently selected mode
  $rect <929,489,1169,529>
  method void StartVideo()
  {
    // Build the video path for the currently selected mode
    var string source = VideoSources[CtrlBar.SelectedIndex];

    // Prepend local file path prefix in Prototyper/Composer
    $if $prototyper || $composer
    source = "file://..\\..\\..\\Extensions\\ExternVideo\\Media\\" + source;
    $endif

    // Assign source, unpause playback and show the video view
    VideoSource.Name = source;
    VideoSource.Paused = false;
    VideoView.Visible = true;
  }

  // Stop video playback and free decoder memory
  $rect <929,529,1169,569>
  method void StopVideo()
  {
    // Hide the video view and clear source to release decoder resources
    VideoView.Visible = false;
    VideoSource.Name = "";
  }

  // Handle video state changes - rewind to frame 0 on end-of-stream for looping
  $rect <929,569,1169,609>
  slot OnVideoStateChanged
  {
    var Resources::ExternVideo externVideo = (Resources::ExternVideo)sender;
    var Resources::ExternVideoState state = externVideo.GetState();

    switch ( state )
    {
      case Resources::ExternVideoState.EndOfStreamReached:
      {
        if ( TimerState == Application::TimerStateEnum.Running )
        {
          $if !$prototyper
          // Seamless rewind to frame 0 via native call — no file reopen.
          // Also re-enable the update timer and reset the stored state,
          // because the Chora ExternVideo disables the timer on EOS.
          native ( externVideo )
          {
            extern void EwExternVideoRewind( XHandle aInstance, int aFrameNumber );
            XHandle inst = ((ResourcesExternVideo)externVideo)->instance;
            if ( inst )
            {
              EwExternVideoRewind( inst, 0 );

              /* Re-enable the 5ms update timer that was disabled on EOS */
              CoreTimer_OnSetEnabled( &((ResourcesExternVideo)externVideo)->updateTimer, 1 );

              /* Reset stored state so next onUpdate doesn't re-trigger EOS */
              ((ResourcesExternVideo)externVideo)->state = ResourcesExternVideoStatePlaying;
            }
          }
          $else
          // Prototyper fallback: reload video via Name reassignment
          postsignal OnVideoRestart;
          $endif
        }
      }

      default:
        ;
    }
  }

  // Prototyper-only: step 1 of video loop - clear source to release decoder
  $rect <929,609,1169,649>
  slot OnVideoRestart
  {
    sender; // consume unused parameter to suppress compiler warning

    // Clear the video source to release the decoder, then re-assign in next frame
    VideoSource.Name = "";
    postsignal OnVideoReload;
  }

  // Prototyper-only: Step 2: re-assign the source to start from frame 0
  $rect <929,649,1169,689>
  slot OnVideoReload
  {
    sender; // consume unused parameter to suppress compiler warning

    // Re-assign the video source to restart playback from frame 0
    var string source = VideoSources[CtrlBar.SelectedIndex];

    $if $prototyper || $composer
    source = "file://..\\..\\..\\Extensions\\ExternVideo\\Media\\" + source;
    $endif

    VideoSource.Name = source;
  }

  // Initialization
  note group Note1
  {
    attr Bounds = <380,-9,900,188>;
  }

  // Device Class Related Code
  note group Note2
  {
    attr Bounds = <909,-9,1189,400>;
  }

  // Key Handling for Prototyper
  note group Note3
  {
    attr Bounds = <1200,-9,1480,429>;
  }

  // State Handling
  note group Note4
  {
    attr Bounds = <380,202,900,531>;
  }

  // Video Integration
  note group Note5
  {
    attr Bounds = <909,409,1189,709>;
  }

  // Control Bar Callbacks
  note group Note6
  {
    attr Bounds = <380,543,900,709>;
  }

  // Directives to adapt the order of the above members according to how these members 
  // where arranged when the project content was stored. In this manner the storage 
  // and the expected order of the members don't depend. Merging of changes in the 
  // project files is simplified.
  $member Init
  $member Bounds
  $member Background
  $member BackgroundNext
  $member BgFadeEffect
  $member OnBgFadeDone
  $member VideoView
  $member Backgrounds
  $member DarkBackgrounds
  $member TimerCfg
  $member DoneMsg
  $member CtrlBar
  $member ProgressInd
  $member HandleArrowAction
  $member DeviceRef
  $member PreviousAdcValue
  $member EncoderObserver
  $member onEncoderChange
  $member HardButtonHandler
  $member HardButtonTimer
  $member onHardButtonEvent
  $member OnHardButtonTimerDone
  $member KeyEnterHandler
  $member onKeyEnter
  $member KeyLeftHandler
  $member KeyRightHandler
  $member onKeyLeft
  $member onKeyRight
  $member onKeyLeftHold
  $member onKeyRightHold
  $member KeyHoldGateTimer
  $member TimerState
  $member RoundMaskView
  $member OnControlBarAction
  $member OnCountdownComplete
  $member OnProgressTick
  $member OnDoneExpired
  $member OnSelectionChanged
  $member OnCarouselTouch
  $member VideoSource
  $member VideoSources
  $member StartVideo
  $member StopVideo
  $member OnVideoStateChanged
  $member OnVideoRestart
  $member OnVideoReload
  $member Note1
  $member Note2
  $member Note3
  $member Note4
  $member Note5
  $member Note6
}

// Timer display component - shows MM:SS text during time selection
